# API Configuration
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30

# LiteLLM Configuration
LITELLM_MODEL=text-embedding-qwen3-embedding-0.6b
# If you are running a local LM Studio instance, set LITELLM_API_BASE to your LM Studio URL
# and keep the model name exactly as LM Studio exposes it (do not rely on auto-prefixing).
LITELLM_API_BASE=http://localhost:1234/v1
LITELLM_API_KEY=sk-your-key-here

# Embedding tuning
# Number of texts sent per HTTP request to the embedding provider (default: 16)
EMBEDDING_CHUNK_SIZE=8
# Minimum chunk size to attempt before giving up
EMBEDDING_MIN_CHUNK_SIZE=1
# Number of retries for each HTTP embedding request
EMBEDDING_RETRIES=5
# Per-request timeout (seconds) for embedding HTTP calls (increase for busy/slow providers)
EMBEDDING_TIMEOUT=300

# Optional: Cloud Providers
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/banking_classification

# Development
DEBUG=false